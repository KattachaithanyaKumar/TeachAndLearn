# --- Vite (public in the browser bundle) ---
# Match sanity/sanity.config.ts project & dataset.
#
# Admin UI is mounted at /admin — set so routes and links use the /admin prefix.
# VITE_ADMIN_BASE=/admin

VITE_SANITY_PROJECT_ID=fsko8ofn
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01

# Public write key for the marketing contact flow (`contact_submission` documents).
# Create at https://www.sanity.io/manage → API → Tokens. Add site URL under CORS origins.
VITE_SANITY_WRITE_TOKEN=

# Optional; must match ADMIN_API_KEY when using header-based API access from the browser.
# VITE_ADMIN_API_KEY=

# Optional API origin (no trailing slash). Omit so `/api` uses the same origin: Vite dev proxies to
# `server/index.js`; Netlify serves `/api/*` via `netlify/functions/api.mjs` (see netlify.toml).
# VITE_API_URL=

# --- Express + Netlify Functions (server/index.js, netlify/functions/api.mjs) — copy to `.env` locally ---
# PORT=3001
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_VERSION=2024-01-01
# SANITY_API_WRITE_TOKEN=
# SESSION_SECRET=
# COOKIE_SECURE=false
# On Netlify (HTTPS), set COOKIE_SECURE=true in Site settings → Environment variables.
# SANITY_AUTH_DATASET=production
# ADMIN_API_KEY=

# Bootstrap admin login: deploy `admin_user` schema (sanity/), create user in Studio,
# hash password with `npm run hash-password -- "YourPassword"`, set SESSION_SECRET, then `npm run dev`.
