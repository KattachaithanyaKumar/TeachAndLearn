# --- Vite (public in the browser bundle) ---
# Match sanity/sanity.config.ts project & dataset.
#
# Admin UI is mounted at /admin — set so routes and links use the /admin prefix.
# VITE_ADMIN_BASE=/admin

# Canonical production origin (no trailing slash). Required for `npm run build` (OG URLs, sitemap).
# Set the same in Netlify → Site settings → Environment variables.
# VITE_SITE_URL=https://www.example.com

VITE_SANITY_PROJECT_ID=fsko8ofn
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01

# Write token: contact form + admin UI (GROQ/mutations). Create at sanity.io/manage → API → Tokens.
VITE_SANITY_WRITE_TOKEN=

# --- Admin (/admin) ---
# Login form: username + password checked against `admin_user` in Sanity (bcrypt).
# API access uses VITE_SANITY_WRITE_TOKEN from env (inlined at build). Session storage only keeps
# the signed-in username for this tab.
# Optional if admin_user documents live in a different dataset than content:
# VITE_SANITY_AUTH_DATASET=production

# --- Optional: local Express API (server/index.js) — not required for the admin UI ---
# PORT=3001
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_VERSION=2024-01-01
# SANITY_API_WRITE_TOKEN=
# SESSION_SECRET=
# COOKIE_SECURE=false
# SANITY_AUTH_DATASET=production
# ADMIN_API_KEY=

# --- Optional: website form emails (server-side) ---
# Frontend will call `/api/public/*` on same origin. For local dev where Vite and API run on different ports:
# VITE_SERVER_API_ORIGIN=http://localhost:3001
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Teach & Learn <no-reply@teachandlearn.example>"
#
# Per-form recipients (comma-separated for multiple). If not set, emails are skipped but submissions still save.
# CONTACT_SUBMISSION_TO_HOME_BOOK=appointments@teachandlearn.example
# CONTACT_SUBMISSION_TO_CONTACT_PAGE=info@teachandlearn.example
# CONTACT_SUBMISSION_TO_DEFAULT=info@teachandlearn.example
# FRANCHISE_INQUIRY_TO=franchise@teachandlearn.example
#
# Optional CC for all form emails:
# FORM_EMAIL_CC=admin@teachandlearn.example
